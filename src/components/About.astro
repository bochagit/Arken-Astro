---
import { getLangFromUrl, useTranslations, type Language } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url) as Language
const t = useTranslations(lang)
---

<section class="about" id="quienes-somos">
	<div class="about__logo-container">
		<img src="/Fotos/Logo.webp" alt="Arken Games Logo" class="about__logo" />
	</div>
	<div class="about__text">
		<h2 class="about__title">{t('about.title')}</h2>
		<p>
			{t('about.text1')}
		</p>
		<p>
			{t('about.text2')}
		</p>
	</div>
</section>
