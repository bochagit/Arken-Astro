---
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl, type Language } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url) as Language
const t = useTranslations(lang)
const otherLang: Language = lang === 'es' ? 'en' : 'es'
const pathWithoutLocale = Astro.url.pathname.replace(/^\/(es|en)/, '')
---

<header class="header">
	<input type="checkbox" id="menu-toggle" class="header__checkbox" />
	<label for="menu-toggle" class="header__menu-toggle" role="button">
		<img src="/Fotos/Nav-icon.webp" alt="Icono abrir menu" class="menu-toggle__icon" />
	</label>
	<nav class="header__nav">
		<ul class="header__nav-list">
			<div class="header__logo-container">
				<img
					src="/Fotos/Logo.webp"
					alt="Logo Arken Games"
					class="header__logo"
					style="view-transition-name: arken-logo"
				/>
			</div>
			<li class="header__nav-item">
				<a href={getRelativeLocaleUrl(lang, '/')}>{t('nav.inicio')}</a>
			</li>
			<li class="header__nav-item">
				<a href={getRelativeLocaleUrl(lang, '/juegos')}>{t('nav.juegos')}</a>
			</li>
			<li class="header__nav-item">
				<a href="https://arkengames.mitiendanube.com/" rel="noopener noreferrer" target="_blank"
					>{t('nav.tienda')}</a
				>
			</li>
			<li class="header__nav-item">
				<a href={getRelativeLocaleUrl(lang, '/#quienes-somos')}>{t('nav.quienes')}</a>
			</li>
			<li class="header__nav-item">
				<a href={getRelativeLocaleUrl(lang, '/#contact')}>{t('nav.contacto')}</a>
			</li>
		</ul>
		<div class="lang-switcher">
			<a
				href={`/${otherLang}${pathWithoutLocale}`}
				class={`lang-link ${lang === 'es' ? 'active' : ''}`}
			>
				ES
			</a>
			<span class="lang-divider">/</span>
			<a
				href={`/${otherLang}${pathWithoutLocale}`}
				class={`lang-link ${lang === 'en' ? 'active' : ''}`}
			>
				EN
			</a>
		</div>
	</nav>
</header>
