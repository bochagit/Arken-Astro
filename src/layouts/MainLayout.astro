---
import { getLangFromUrl, type Language } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url) as Language
const langDir = lang === 'es' ? 'es' : 'en'

import '../styles/global.css'
import '../styles/games.css'
import '../styles/fonts.css'
---

<!doctype html>
<html lang={langDir}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<title>{Astro.props.title}</title>

		<link rel="icon" href="/Fotos/Logo.webp" type="image/webp" />

		<meta
			name="description"
			content="Pagina web de Arken Games, editorial de juegos de mesa en Argentina."
		/>
		<meta name="author" content="Gonzalo Cardozo - github.com/bochagit" />

		<link rel="alternate" hreflang="es" href="https://arkengames.com/es" />
		<link rel="alternate" hreflang="en" href="https://arkengames.com/en" />

		<!-- Google Analytics -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-CKXG8YDXR0"></script>
		<script is:inline>
			/* eslint-disable */
			window.dataLayer = window.dataLayer || []

			function gtag() {
				dataLayer.push(arguments)
			}

			gtag('js', new Date())
			gtag('config', 'G-CKXG8YDXR0')
			/* eslint-enable */
		</script>
	</head>
	<body>
		<slot />
		<script is:inline src="/Scripts/detect-language.js"></script>
		<script type="module" src="/Scripts/modal.js"></script>
		<script is:inline src="/Scripts/header-scroll.js"></script>
	</body>
</html>
