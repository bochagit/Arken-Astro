---
import MainLayout from '../../layouts/MainLayout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import '../../styles/torneos.css'
---

<MainLayout title="Torneos | Arken">
	<div class="wallpaper__overlay">
		<Header />

		<main class="torneos">
			<section class="torneos__intro">
				<img src="/Fotos/Torneos_banner.png" alt="Banner torneos" class="torneos__banner" />
				<h2 class="torneos__title">Formatos de torneos</h2>
				<div class="torneos__accordion">
					<details class="torneos__item torneos__item--red" open>
						<summary>Conscript</summary>
						<div class="torneos__content">
							<div class="torneos__content-grid">
								<img src="/Fotos/CONSCRIPT.png" alt="Formato Conscript" class="torneos__content-image" />
								<div class="torneos__content-copy">
									<h3>
										Formato de eliminación donde construís tu equipo a medida que avanzás.
									</h3>
									<ul>
										<li>Torneo 1 vs 1 de eliminación directa. Cada ronda es una partida única.</li>
										<li>Cada jugador comienza con 2 personajes asignados.</li>
										<li>Al ganar una ronda, descartás el personaje ganador.</li>
										<li>Incorporás todos los personajes de tu rival a tu roster.</li>
										<li>Elegís 3 personajes para la siguiente ronda.</li>
										<li>Ideal para jugadores que buscan partidas dinámicas y adaptación constante.</li>
									</ul>
								</div>
							</div>
						</div>
					</details>

					<details class="torneos__item torneos__item--blue">
						<summary>Roster</summary>
						<div class="torneos__content">
							<div class="torneos__content-grid torneos__content-grid--reverse">
								<img src="/Fotos/ROSTER.png" alt="Formato Rooster" class="torneos__content-image" />
								<div class="torneos__content-copy">
									<h3>
										Formato competitivo avanzado con múltiples partidas por ronda
									</h3>
									<ul>
										<li>Torneo competitivo 1 vs 1 en formato suizo, con dos partidas por ronda.</li>
										<li>Cada jugador registra un roster de 4 personajes</li>
										<li>En cada ronda se proponen 2 enfrentamientos posibles</li>
										<li>El primero se define al azar (vale 1 punto)</li>
										<li>El ganador elige el segundo enfrentamiento (vale 2 puntos)</li>
									</ul>
									<p>Pensado para jugadores con experiencia que buscan profundidad estratégica</p>
								</div>
							</div>
						</div>
					</details>

					<details class="torneos__item torneos__item--purple">
						<summary>2 vs 2</summary>
						<div class="torneos__content">
							<div class="torneos__content-grid">
								<img src="/Fotos/2VS2.png" alt="Formato 2 vs 2" class="torneos__content-image" />
								<div class="torneos__content-copy">
									<h3>
										Formato en equipo donde la coordinación se une a la estrategia
									</h3>
									<p>Torneo en equipos de 2 jugadores, en formato suizo. Se juega una partida por ronda.</p>
									<ul>
										<li>Cada equipo arma un roster de 6 personajes compartidos</li>
										<li>Antes de cada ronda, se banea 1 personaje del rival</li>
										<li>Cada equipo elige 2 personajes para jugar</li>
										<li>Se gana eliminando ambos héroes rivales</li>
									</ul>
									<p>Ideal para jugar en equipo y coordinar estrategias</p>
								</div>
							</div>
						</div>
					</details>
				</div>

				<div class="torneos__organiza-section">
					<div class="torneos__organiza-content">
						<h2 class="torneos__organiza-title">Organizá torneos oficiales</h2>
						<p class="torneos__organiza-subtitle">Sumate como anfitrión y forma parte del circuito de Unmatched en Argentina</p>
						<ul class="torneos__organiza-benefits">
							<li>Usa formatos oficiales (Conscript, 2vs2, Rooster)</li>
							<li>Difusión en canales de Arken Games</li>
							<li>Premios oficiales</li>
							<li>Sumate al crecimiento de la comunidad</li>
						</ul>
						<button class="torneos__organiza-button">Postularme como anfitrión</button>
					</div>
					<div class="torneos__carousel-container" data-carousel-images="/Fotos/Torneos_1.jpg,/Fotos/Torneos_2.jpg,/Fotos/Torneos_3.jpg,/Fotos/Torneos_4.jpg,/Fotos/Torneos_5.jpg,/Fotos/Torneos_6.jpg,/Fotos/Torneos_7.jpg,/Fotos/Torneos_8.jpg">
						<button class="torneos__carousel-arrow torneos__carousel-arrow--prev" id="carousel-prev">‹</button>
						<div class="torneos__carousel-viewer">
							<img class="torneos__carousel-image" src="/Fotos/Torneos_1.jpg" alt="Galería anfitrión" data-index="0" />
						</div>
						<button class="torneos__carousel-arrow torneos__carousel-arrow--next" id="carousel-next">›</button>
					</div>
				</div>

				<section class="torneos__calendar">
					<h2 class="torneos__title">Calendario</h2>
					<div id="fc-calendar"></div>
				</section>

				<div class="torneos__wp-banner">
					<img class="torneos__wp-image" src="/Fotos/Banner_torneos-WP.png" alt="Unirse al canal de WhatsApp">
					<div class="torneos__wp-text">
						<h3 class="torneos__wp-title">No te pierdas ningún torneo</h3>
						<p class="torneos__wp-text-sub">
							Fechas, cupos y novedades de Unmatched en Argentina
						</p>
						<p>
							Acceso anticipado a lanzamientos
						</p>
						<button class="torneos__wp-button">
							<img src="/Fotos/Whatsapp-icon.webp">
							<h3>Unirme al canal de WhatsApp</h3>
						</button>
					</div>
				</div>
			</section>
		</main>

		<Footer />
	</div>
<script type="module"> 
	import { Calendar } from 'https://esm.sh/@fullcalendar/core@6.1.20';
	import dayGridPlugin from 'https://esm.sh/@fullcalendar/daygrid@6.1.20'; 
	import timeGridPlugin from 'https://esm.sh/@fullcalendar/timegrid@6.1.20';
	import googleCalendarPlugin from 'https://esm.sh/@fullcalendar/google-calendar@6.1.20'; 
	import esLocale from 'https://esm.sh/@fullcalendar/core@6.1.20/locales/es';
	
	document.addEventListener('DOMContentLoaded', () => { 
		const el = document.getElementById('fc-calendar')
		if (!el) return 
		const calendar = new Calendar(el, {
			plugins: [dayGridPlugin, timeGridPlugin, googleCalendarPlugin],
			initialView: 'dayGridMonth',
			locales: [esLocale],
			locale: 'es',
			buttonText: {
				today: 'Hoy',
				month: 'Mes',
				week: 'Semana',
				day: 'Día'
			},
			googleCalendarApiKey: 'YOUR_API_KEY',
			events: { googleCalendarId: 'YOUR_CALENDAR_ID' },
			timeZone: 'America/Argentina/Buenos_Aires',
			height: 'auto',
			headerToolbar: { left: 'prev,next today', center: 'title', right: 'dayGridMonth,timeGridWeek,timeGridDay' },
			
			eventClick(info) { 
				if (info.event.url) { 
					info.jsEvent.preventDefault() 
					window.open(info.event.url, '_blank') 
					} 
				} 
			}) 
		calendar.render() 
	})
</script>
</MainLayout>
<script>
	const initializeCarousel = (container: HTMLElement) => {
		const imageList = (container.dataset.carouselImages || '')
			.split(',')
			.map((imagePath: string) => imagePath.trim())
			.filter(Boolean)

		const image = container.querySelector<HTMLImageElement>('.torneos__carousel-image')
		const prevButton = container.querySelector<HTMLButtonElement>('.torneos__carousel-arrow--prev')
		const nextButton = container.querySelector<HTMLButtonElement>('.torneos__carousel-arrow--next')

		if (!image || !prevButton || !nextButton || imageList.length === 0) {
			return
		}

		let currentIndex = 0

		const renderImage = () => {
			image.src = imageList[currentIndex]
			image.dataset.index = String(currentIndex)
		}

		renderImage()

		prevButton.addEventListener('click', () => {
			currentIndex = (currentIndex - 1 + imageList.length) % imageList.length
			renderImage()
		})

		nextButton.addEventListener('click', () => {
			currentIndex = (currentIndex + 1) % imageList.length
			renderImage()
		})
	}

	const bootCarousel = () => {
		document
			.querySelectorAll<HTMLElement>('.torneos__carousel-container')
			.forEach((container) => initializeCarousel(container))
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', bootCarousel)
	} else {
		bootCarousel()
	}
</script>
