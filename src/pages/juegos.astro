---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro"; 
---

<MainLayout title="Juegos | Arken">
  <Header />
  <main class="juegos">
    <div class="juegos__wrapper">
        <h2 class="juegos__title">Conoce nuestros juegos:</h2>
        <a href="/juegos/rh-vs-bf">
            <img src="/Fotos/Juegos_RHvsBF.webp" alt="Banner juego Unmatched: Robin Hood vs Bigfoot" class="juegos__image">
        </a>
        <a href="/juegos/vol1">
            <img src="/Fotos/Juegos_Vol1.webp" alt="Banner juego Unmatched: Battle of legends Volume one" class="juegos__image">
        </a>
        <a href="/juegos/sunrise">
            <img src="/Fotos/Juegos_Sunrise.webp" alt="Banner juego Sunrise Sunset" class="juegos__image">
        </a>
    </div>
  </main>
  <Footer />
</MainLayout>