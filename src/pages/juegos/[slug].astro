					></path>
					<path
						d="M15.8,17.1c-1.4,0-2.5-1.1-2.5-2.5V2.5c0-1.4,1.1-2.5,2.5-2.5s2.5,1.1,2.5,2.5v12.1c0,1.4-1.1,2.5-2.5,2.5Z"
					></path>
					<path
						d="M82.5,17.1c-1.4,0-2.5-1.1-2.5-2.5V2.5c0-1.4,1.1-2.5,2.5-2.5s2.5,1.1,2.5,2.5v12.1c0,1.4-1.1,2.5-2.5,2.5Z"
					></path>
					<path
						d="M97.3,31.7H2.7c-1.4,0-2.5-1.1-2.5-2.5s1.1-2.5,2.5-2.5h94.6c1.4,0,2.5,1.1,2.5,2.5s-1.1,2.5-2.5,2.5Z"
					></path>
					<path
						d="M63.3,52.2c-.7,0-1.3-.3-1.8-.7l-11.3-11.3-11.3,11.3c-1.1.9-2.6.7-3.5-.3-.8-.9-.8-2.3,0-3.2l13.1-13.1c1-1,2.6-1,3.5,0l13.1,13.1c1,1,1,2.6,0,3.5-.5.5-1.1.7-1.7.7h0Z"
					></path>
					<path
						d="M50.2,77.2c-.7,0-1.3-.3-1.8-.7l-13.1-13.1c-.9-1-.8-2.6.2-3.5.9-.8,2.4-.8,3.3,0l11.3,11.3,11.3-11.3c1-.9,2.6-.8,3.5.2.8.9.8,2.4,0,3.3l-13.1,13.1c-.5.5-1.1.7-1.8.7Z"
					></path>
				</svg>{game.data.age} Años
			</li>
		</ul>

		<article class="main">
			<Content />
		</article>

		{
			game.data.gallery && game.data.gallery.length > 0 && (
				<>
					<div class="gallery__title-container">
						<div class="gallery__title-line" />
						<h2 class="gallery__title">Galería</h2>
						<div class="gallery__title-line" />
					</div>
					<section class="gallery">
						{game.data.gallery.map((photo) => (
							<img src={photo} alt="Foto del juego" />
						))}
					</section>
					<span class="photo__copyright">Photos by Board Game Shot</span>
				</>
			)
		}

		{
			relatedGamesList.length > 0 && (
				<section class="similar">
					<div class="similar__title-container">
						<div class="similar__title-line" />
						<h2 class="similar__title">Juegos relacionados</h2>
						<div class="similar__title-line" />
					</div>
					<div class="similar__game-container">
						{relatedGamesList.map((relatedGame) => (
							<div class="similar__game">
								<a href={`/juegos/${relatedGame.id}`} class="similar__game-link">
									<img
										src={relatedGame.data.box}
										alt={relatedGame.data.title}
										class="similar__game-box"
									/>
									<p class="similar__game-name">{relatedGame.data.title}</p>
								</a>
							</div>
						))}
					</div>
				</section>
			)
		}

		<Footer />
	</div>
</MainLayout>
