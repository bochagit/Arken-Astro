---
import type { GetStaticPaths } from 'astro'
import { getCollection, render, type CollectionEntry } from 'astro:content'
import MainLayout from '../../layouts/MainLayout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import '../../styles/games.css'

export const getStaticPaths: GetStaticPaths = async () => {
	const games = await getCollection('games')

	return games.map((game) => ({
		params: { slug: game.id },
		props: { game, allGames: games }
	}))
}

interface Props {
	game: CollectionEntry<'games'>
	allGames: CollectionEntry<'games'>[]
}

const { game, allGames } = Astro.props as Props
const { Content } = await render(game)

const relatedGamesList = game.data.relatedGames
	? allGames.filter((g) => game.data.relatedGames?.includes(g.id))
	: []
---

<MainLayout title={game.data.title}>
	<div class="wallpaper__overlay">
		<Header />

		<h1 class="title">{game.data.title}</h1>

		<div class="banner__container">
			<img class="banner" src={game.data.banner} alt={game.data.title} />
		</div>

		<ul class="main__icons">
			<li class="main__icon-item">
				<svg
					xmlns="http://www.w3.org/2000/svg"
					id="Capa_1"
					version="1.1"
					viewBox="0 0 100 125"
					class="main__icon-icon --players"
				>
