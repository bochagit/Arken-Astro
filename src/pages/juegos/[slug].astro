---
import type { GetStaticPaths } from 'astro'
import { getCollection, render, type CollectionEntry } from 'astro:content'
import MainLayout from '../../layouts/MainLayout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import '../../styles/games.css'

export const getStaticPaths: GetStaticPaths = async () => {
	const games = await getCollection('games')

	return games.map((game) => ({
		params: { slug: game.id },
		props: { game, allGames: games }
	}))
}

interface Props {
	game: CollectionEntry<'games'>
	allGames: CollectionEntry<'games'>[]
}

const { game, allGames } = Astro.props as Props
const { Content } = await render(game)

const relatedGamesList = game.data.relatedGames
	? allGames.filter((g) => game.data.relatedGames?.includes(g.id))
	: []

function getYouTubeEmbedUrl(url?: string): string | null {
	if (!url) return null

	const match = url.match(
		/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([A-Za-z0-9_-]{11})/
	)

	if (!match) return null

	return `https://www.youtube.com/embed/${match[1]}`
}

const youtubeLinks = [
	...(game.data.youtubeUrls ?? []),
	...(game.data.youtubeUrl ? [game.data.youtubeUrl] : [])
]
const youtubeEmbedUrls = youtubeLinks
	.map((url) => getYouTubeEmbedUrl(url))
	.filter((url): url is string => Boolean(url))

const hasGalleryContent = (game.data.gallery?.length ?? 0) > 0
const hasVideoContent = youtubeEmbedUrls.length > 0
---

<MainLayout title={game.data.title}>
	<div class="wallpaper__overlay">
		<Header />

		<h1 class="title">{game.data.title}</h1>

		<div class="banner__container">
			<img class="banner" src={game.data.banner} alt={game.data.title} />
		</div>

		<div class="main__container">
			<div class="main__game-description">
				<ul class="main__icons">
					<li class="main__icon-item">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							id="Capa_1"
							version="1.1"
							viewBox="0 0 100 125"
							class="main__icon-icon --players"
						>
							<!-- Generator: Adobe Illustrator 29.0.0, SVG Export Plug-In . SVG Version: 2.1.0 Build 186)  -->
							<path
								d="M39.5,51.3c2.6-1.2,4.3-3.8,4.3-6.8s-3.4-7.5-7.5-7.5-7.5,3.4-7.5,7.5,1.8,5.6,4.4,6.8c-4.8,2.5-8.3,10.5-8.3,20h16.4c0-5.8,1-11.2,2.7-15.7-1.3-2-2.7-3.5-4.4-4.3Z"
							></path>
							<path
								d="M45,71.3h29.2c0-12.1-4.5-22.2-10.6-25.4,3.3-1.5,5.5-4.8,5.5-8.6s-4.3-9.5-9.5-9.5-9.5,4.3-9.5,9.5,2.3,7.1,5.5,8.6c-6.1,3.2-10.6,13.3-10.6,25.4Z"
							></path>
						</svg>{game.data.players} Jugadores
					</li>
					<li class="main__icon-item">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							id="Capa_1"
							version="1.1"
							viewBox="0 0 100 125"
							class="main__icon-icon"
						>
							<!-- Generator: Adobe Illustrator 29.0.0, SVG Export Plug-In . SVG Version: 2.1.0 Build 186)  -->
							<path
								d="M54,16.8c8.2.8,15.7,3.9,21.8,8.7l2.6-2.6-2-2c-.8-.8-.8-2.2,0-3l2.8-2.9c.8-.8,2.2-.8,3,0l8.2,8.2c.8.8.8,2.2,0,3l-2.8,2.9c-.8.8-2.2.8-3,0l-2-2-2.4,2.4c7.1,7.5,11.4,17.5,11.4,28.6s-4.7,21.9-12.2,29.5c-7.6,7.5-18,12.2-29.5,12.2s-21.9-4.7-29.5-12.2c-7.5-7.6-12.2-18-12.2-29.5s4.3-21.2,11.4-28.6l-2.4-2.4-2,2c-.8.8-2.2.8-3,0l-2.9-2.9c-.8-.8-.8-2.2,0-3l8.2-8.2c.8-.8,2.2-.8,3,0l2.9,2.9c.8.8.8,2.2,0,3l-2,2,2.6,2.6c6.1-4.8,13.6-8,21.8-8.7v-5.9h-3.7c-1.5,0-2.8-1.3-2.8-2.8V2.8C39.5,1.3,40.8,0,42.3,0h15.4C59.2,0,60.5,1.3,60.5,2.8v5.3c0,1.6-1.3,2.8-2.8,2.8h-3.7v5.9h0ZM74.2,72.3l-24.2-14v-27.9c-15.4,0-27.9,12.5-27.9,27.9s12.5,27.9,27.9,27.9,19.3-5.6,24.2-14h0ZM74.3,34c-6.2-6.2-14.8-10.1-24.3-10.1s-18.1,3.9-24.3,10.1c-6.2,6.2-10.1,14.8-10.1,24.3s3.9,18.1,10.1,24.3c6.2,6.2,14.8,10.1,24.3,10.1s18.1-3.8,24.3-10.1c6.2-6.2,10.1-14.8,10.1-24.3s-3.8-18.1-10.1-24.3Z"
							></path>
						</svg>{game.data.duration} Minutos
					</li>
					<li class="main__icon-item">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							id="Capa_1"
							version="1.1"
							viewBox="0 0 100 108.4"
							class="main__icon-icon --age"
						>
							<!-- Generator: Adobe Illustrator 29.0.0, SVG Export Plug-In . SVG Version: 2.1.0 Build 186)  -->
							<path
								d="M91,86.7H9c-5,0-9-4-9-9V17.6c0-5,4-9,9-9h82c5,0,9,4,9,9v60.2c0,5-4,9-9,9ZM9,13.6c-2.2,0-4,1.8-4,4v60.2c0,2.2,1.8,4,4,4h82c2.2,0,4-1.8,4-4V17.6c0-2.2-1.8-4-4-4H9Z"
							></path>
							<path
								d="M15.8,17.1c-1.4,0-2.5-1.1-2.5-2.5V2.5c0-1.4,1.1-2.5,2.5-2.5s2.5,1.1,2.5,2.5v12.1c0,1.4-1.1,2.5-2.5,2.5Z"
							></path>
							<path
								d="M82.5,17.1c-1.4,0-2.5-1.1-2.5-2.5V2.5c0-1.4,1.1-2.5,2.5-2.5s2.5,1.1,2.5,2.5v12.1c0,1.4-1.1,2.5-2.5,2.5Z"
							></path>
							<path
								d="M97.3,31.7H2.7c-1.4,0-2.5-1.1-2.5-2.5s1.1-2.5,2.5-2.5h94.6c1.4,0,2.5,1.1,2.5,2.5s-1.1,2.5-2.5,2.5Z"
							></path>
							<path
								d="M63.3,52.2c-.7,0-1.3-.3-1.8-.7l-11.3-11.3-11.3,11.3c-1.1.9-2.6.7-3.5-.3-.8-.9-.8-2.3,0-3.2l13.1-13.1c1-1,2.6-1,3.5,0l13.1,13.1c1,1,1,2.6,0,3.5-.5.5-1.1.7-1.7.7h0Z"
							></path>
							<path
								d="M50.2,77.2c-.7,0-1.3-.3-1.8-.7l-13.1-13.1c-.9-1-.8-2.6.2-3.5.9-.8,2.4-.8,3.3,0l11.3,11.3,11.3-11.3c1-.9,2.6-.8,3.5.2.8.9.8,2.4,0,3.3l-13.1,13.1c-.5.5-1.1.7-1.8.7Z"
							></path>
						</svg>{game.data.age} Años
					</li>
				</ul>

				<div class="main__game-buy main__game-buy--mobile" aria-label="Compra del juego">
					<div class="main__game-box-frame">
						<img src={game.data.box} alt={`Caja ${game.data.title}`} class="main__game-box-image" />
					</div>

					<div class="main__game-buy-content">
						<p class="main__game-buy-title">{game.data.title}</p>

						{
							game.data.buyUrl ? (
								<a href={game.data.buyUrl} target="_blank" rel="noreferrer" class="buy__button">
									Comprar
								</a>
							) : (
								<button type="button" class="buy__button buy__button--disabled" disabled>
									Proximamente
								</button>
							)
						}
					</div>
				</div>

				<article class="main">
					<Content />
				</article>
			</div>

			<aside class="main__game-buy main__game-buy--desktop" aria-label="Compra del juego">
				<div class="main__game-box-frame">
					<img src={game.data.box} alt={`Caja ${game.data.title}`} class="main__game-box-image" />
				</div>

				{
					game.data.buyUrl ? (
						<a href={game.data.buyUrl} target="_blank" rel="noreferrer" class="buy__button">
							Comprar
						</a>
					) : (
						<button type="button" class="buy__button buy__button--disabled" disabled>
							Proximamente
						</button>
					)
				}
			</aside>
		</div>

		{
			hasGalleryContent && (
				<>
					<div class="gallery__title-container">
						<div class="gallery__title-line" />
						<h2 class="gallery__title">Galería</h2>
						<div class="gallery__title-line" />
					</div>

					<section class="gallery">
						{(game.data.gallery ?? []).map((photo) => (
							<img src={photo} alt={`Foto de ${game.data.title}`} data-gallery-image="true" />
						))}
					</section>

					<span class="photo__copyright">Photos by Board Game Shot</span>
				</>
			)
		}

		{
			hasVideoContent && (
				<>
					<div class="gallery__title-container">
						<div class="gallery__title-line" />
						<h2 class="gallery__title">Videos</h2>
						<div class="gallery__title-line" />
					</div>

					<section class="gallery gallery--videos">
						{youtubeEmbedUrls.map((url, index) => (
							<div class="gallery__video-item">
								<iframe
									src={url}
									title={`Video ${index + 1} de ${game.data.title}`}
									loading="lazy"
									allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
									referrerpolicy="strict-origin-when-cross-origin"
									allowfullscreen
								></iframe>
							</div>
						))}
					</section>
				</>
			)
		}

		{
			relatedGamesList.length > 0 && (
				<section class="similar">
					<div class="similar__title-container">
						<div class="similar__title-line" />
						<h2 class="similar__title">Juegos relacionados</h2>
						<div class="similar__title-line" />
					</div>

					<div class="similar__game-container">
						{relatedGamesList.map((relatedGame) => (
							<div class="similar__game">
								<a href={`/juegos/${relatedGame.id}`} class="similar__game-link">
									<img
										src={relatedGame.data.box}
										alt={relatedGame.data.title}
										class="similar__game-box"
									/>
									<p class="similar__game-name">{relatedGame.data.title}</p>
								</a>
							</div>
						))}
					</div>
				</section>
			)
		}

		<Footer />
	</div>
	<div id="imageModal" class="image-modal" aria-hidden="true">
		<button
			type="button"
			id="modalPrev"
			class="image-modal__nav image-modal__nav--prev"
			aria-label="Foto anterior">&#8249;</button
		>
		<span class="image-modal__close" aria-label="Cerrar modal">&times;</span>
		<img id="modalImg" class="image-modal__content" alt="" />
		<button
			type="button"
			id="modalNext"
			class="image-modal__nav image-modal__nav--next"
			aria-label="Foto siguiente">&#8250;</button
		>
	</div>
</MainLayout>
